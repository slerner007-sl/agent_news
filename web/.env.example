# Where the dev server proxies /api and /health.
# When the frontend is served from the same nginx as the API you can leave this empty.
VITE_API_PROXY=http://localhost:8765

# Absolute base URL for the API. Leave empty to use the proxy / current origin.
# Example for cross-host development: VITE_API_BASE=https://radar.example.com
VITE_API_BASE=
