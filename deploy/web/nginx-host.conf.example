# Host-level nginx vhost for the Agent News (AI Visor) dashboard.
# Drop at /etc/nginx/sites-available/agent-news-web and symlink into sites-enabled.
#
# Current production layout (no Docker):
#   Static SPA  →  /var/www/agent-news-web  (built via: cd web && npm run build)
#   FastAPI     →  127.0.0.1:8765           (systemd: agent-news-web-api.service)
#
# Basic auth protects the entire site. Generate credentials:
#   sudo htpasswd -c /etc/nginx/agent-news.htpasswd <username>

upstream agent_news_web_api { server 127.0.0.1:8765; }

server {
    listen 80;
    listen [::]:80;
    server_name _;

    auth_basic           "AI Visor";
    auth_basic_user_file /etc/nginx/agent-news.htpasswd;

    # Static SPA files
    root /var/www/agent-news-web;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;
    }

    # API proxy
    location /api/ {
        proxy_pass http://agent_news_web_api;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_read_timeout 300s;
    }

    # SSE event stream — disable buffering for real-time delivery
    location /api/v1/events/ {
        proxy_pass http://agent_news_web_api;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 3600s;
        proxy_set_header Connection '';
        proxy_http_version 1.1;
    }

    location = /health {
        auth_basic off;
        proxy_pass http://agent_news_web_api;
        proxy_set_header Host $host;
        access_log off;
    }

    client_max_body_size 12m;
    gzip on;
    gzip_types text/plain text/css application/json application/javascript text/javascript;
}
