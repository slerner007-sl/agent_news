# Where the production SQLite database lives on the VPS.
# Default assumes you run docker compose from deploy/web/, so the
# repository's data/ folder is two levels up.
AGENT_NEWS_DB_HOST_PATH=/home/user1/gosb_bot/data

# Local ports the containers expose on the host (bound to 127.0.0.1).
# The host nginx fronts both — see docs/operations/web-deployment.md.
AGENT_NEWS_WEB_PORT_HOST=8765
AGENT_NEWS_WEB_UI_PORT=8080

# Basic-auth credentials enforced INSIDE the API. Leave both empty to
# rely solely on nginx-level auth. If set, requests must include the
# Authorization header — handy when the API is exposed directly.
AGENT_NEWS_WEB_USER=
AGENT_NEWS_WEB_PASSWORD=

# Comma-separated list of allowed CORS origins. Add your public URL
# for cross-host setups, e.g. https://radar.example.com.
AGENT_NEWS_WEB_CORS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080
